#!/usr/bin/env bash
# handoff — drive the two-agent HANDOFF.md workflow without a human courier.
#
# The Status line in HANDOFF.md's Current Task section is the state machine:
#   READY FOR EXECUTION -> executor's turn
#   READY FOR QA        -> planner's turn
#   CHANGES REQUESTED   -> executor's turn
#   APPROVED            -> human's turn
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TEMPLATE_DIR="$SCRIPT_DIR/../templates"

# INVOCATION DISCIPLINE: the executor prompt is this fixed ritual phrase and
# nothing else. There is deliberately no flag, env var, or argument to add
# instructions — HANDOFF.md must remain the complete, auditable contract
# between the agents. Do not "improve" this.
readonly RITUAL_PROMPT="execute the handoff"

CLAUDE_BIN="${HANDOFF_CLAUDE_BIN:-claude}"
POLL_INTERVAL="${HANDOFF_POLL_INTERVAL:-30}"

usage() {
  cat <<'EOF'
usage: handoff <subcommand> [repo-path]     (repo-path defaults to $PWD)

  status    print the Status line, whose turn it is, and the current Goal
  execute   run the executor headlessly (only when it's the executor's turn)
  runs      list past executor runs from their manifests
  watch     poll Status; auto-execute on executor turns, notify on human/planner turns
  archive   append Current Task / Execution Notes / QA Feedback to HANDOFF-ARCHIVE.md
  init      install the protocol template into a repo (local git excludes, not .gitignore)
  permissions  merge the executor allowlist into the repo's .claude/settings.json,
               adapted to the repo's package manager (yarn/pnpm/npm, via lockfile)

env: HANDOFF_CLAUDE_BIN (default: claude), HANDOFF_POLL_INTERVAL seconds (default: 30)
EOF
}

die() { echo "handoff: $*" >&2; exit 1; }

resolve_repo() {
  local repo="${1:-$PWD}"
  repo="$(cd "$repo" 2>/dev/null && pwd)" || die "no such directory: ${1:-$PWD}"
  [[ -f "$repo/HANDOFF.md" ]] || die "no HANDOFF.md in $repo (run 'handoff init $repo' first?)"
  echo "$repo"
}

# The only '**Status:**' line in the file lives in Current Task.
read_status() {
  sed -n 's/^\*\*Status:\*\* *//p' "$1/HANDOFF.md" | head -n 1 | sed 's/[[:space:]]*$//'
}

turn_for() {
  case "$1" in
    "READY FOR EXECUTION" | "CHANGES REQUESTED") echo "EXECUTOR" ;;
    "READY FOR QA") echo "PLANNER" ;;
    "APPROVED") echo "HUMAN" ;;
    *) echo "UNKNOWN" ;;
  esac
}

# First non-empty line after the '### Goal' heading.
read_goal() {
  awk '/^### Goal/ { found = 1; next } found && NF { print; exit }' "$1/HANDOFF.md"
}

notify() { # title, body
  if command -v osascript >/dev/null 2>&1; then
    osascript -e "display notification \"$2\" with title \"$1\"" >/dev/null 2>&1 || true
  fi
  echo "NOTIFY: $1 — $2"
}

cmd_status() {
  local repo status
  repo="$(resolve_repo "${1:-}")"
  status="$(read_status "$repo")"
  echo "repo:   $repo"
  echo "status: ${status:-"(no Status line found)"}"
  echo "turn:   $(turn_for "$status")"
  echo "goal:   $(read_goal "$repo")"
}

cmd_execute() {
  command -v jq >/dev/null || die "jq is required (brew install jq)"

  local repo status
  repo="$(resolve_repo "${1:-}")"
  status="$(read_status "$repo")"
  case "$status" in
    "READY FOR EXECUTION" | "CHANGES REQUESTED") ;;
    *) die "refusing to execute: Status is '$status' (need READY FOR EXECUTION or CHANGES REQUESTED)" ;;
  esac

  mkdir -p "$repo/.handoff-logs"

  # One executor per repo at a time: a driving planner and a running
  # `handoff watch` must not both fire. mkdir is atomic, so it doubles as a
  # lock; a stale lock left by a crash is removed by hand.
  local lock="$repo/.handoff-logs/execute.lock"
  if ! mkdir "$lock" 2>/dev/null; then
    die "another executor run is in progress (or crashed): remove $lock to clear"
  fi
  trap "rmdir '$lock' 2>/dev/null || true" EXIT INT TERM

  local run_id
  run_id="$(date +%Y%m%d-%H%M%S)-$$"
  local log="$repo/.handoff-logs/${run_id}-execute.log"
  local raw_result="$repo/.handoff-logs/${run_id}-result.json"
  local manifest="$repo/.handoff-logs/${run_id}-manifest.json"

  echo "executor starting in $repo (status: $status)"
  echo "run: $run_id"
  echo "log: $log"

  # Pre-run data capture
  local started_at branch_before head_before
  started_at="$(date +%FT%T%z)"
  branch_before="$(git -C "$repo" branch --show-current 2>/dev/null || echo "")"
  head_before="$(git -C "$repo" rev-parse HEAD 2>/dev/null || echo "")"

  {
    echo "=== Executor run $run_id ==="
    echo "started: $started_at"
    echo "status:  $status"
    echo ""
  } > "$log"

  local start=$SECONDS rc=0
  (
    cd "$repo"
    # Strip inherited ANTHROPIC_*/CLAUDE* env so the executor always runs on
    # its own stored login — if this were invoked from inside another Claude
    # session (e.g. the planner's), leaked auth vars would silently run the
    # executor on the wrong account.
    local v
    for v in $(compgen -e | grep -E '^(ANTHROPIC_|CLAUDE)' || true); do unset "$v"; done
    "$CLAUDE_BIN" -p "$RITUAL_PROMPT" --permission-mode acceptEdits \
      --output-format json > "$raw_result" 2>> "$log" || exit $?
  ) || rc=$?
  rmdir "$lock" 2>/dev/null || true # explicit release: watch reuses this process

  # Post-run data capture
  local dur=$((SECONDS - start))
  local finished_at branch_after head_after new_status
  finished_at="$(date +%FT%T%z)"
  branch_after="$(git -C "$repo" branch --show-current 2>/dev/null || echo "")"
  head_after="$(git -C "$repo" rev-parse HEAD 2>/dev/null || echo "")"
  new_status="$(read_status "$repo")"

  # Commits created during this run
  local commits_json="[]"
  if [[ -n "$head_before" && -n "$head_after" && "$head_before" != "$head_after" ]]; then
    local commit_lines
    commit_lines="$(git -C "$repo" log --format='%H%x09%s' "$head_before..$head_after" 2>/dev/null || echo "")"
    if [[ -n "$commit_lines" ]]; then
      # Determine GitHub base URL from origin remote
      local origin_url github_base=""
      origin_url="$(git -C "$repo" remote get-url origin 2>/dev/null || echo "")"
      if [[ "$origin_url" =~ github\.com[:/]([^/]+)/([^/]+) ]]; then
        local repo_name="${BASH_REMATCH[2]}"
        repo_name="${repo_name%.git}"
        github_base="https://github.com/${BASH_REMATCH[1]}/${repo_name}/commit"
      fi

      commits_json="$(echo "$commit_lines" | jq -R --arg base "$github_base" '
        split("\t") | {
          sha: .[0],
          subject: .[1],
          url: (if $base != "" then ($base + "/" + .[0]) else null end)
        }
      ' | jq -s '.')"
    fi
  fi

  # Parse claude result JSON (graceful degradation if invalid/missing)
  local claude_session_id claude_subtype claude_is_error claude_num_turns
  local claude_duration_ms claude_duration_api_ms claude_cost
  local claude_input_tokens claude_output_tokens
  local claude_cache_creation claude_cache_read claude_result_text
  claude_session_id="null"
  claude_subtype="null"
  claude_is_error="null"
  claude_num_turns="null"
  claude_duration_ms="null"
  claude_duration_api_ms="null"
  claude_cost="null"
  claude_input_tokens="null"
  claude_output_tokens="null"
  claude_cache_creation="null"
  claude_cache_read="null"
  claude_result_text=""

  if [[ -f "$raw_result" ]] && jq empty "$raw_result" 2>/dev/null; then
    claude_session_id="$(jq -r '.session_id // null' "$raw_result")"
    claude_subtype="$(jq -r '.subtype // null' "$raw_result")"
    claude_is_error="$(jq 'if has("is_error") then .is_error else null end' "$raw_result")"
    claude_num_turns="$(jq '.num_turns // null' "$raw_result")"
    claude_duration_ms="$(jq '.duration_ms // null' "$raw_result")"
    claude_duration_api_ms="$(jq '.duration_api_ms // null' "$raw_result")"
    claude_cost="$(jq '.total_cost_usd // null' "$raw_result")"
    claude_input_tokens="$(jq '.usage.input_tokens // null' "$raw_result")"
    claude_output_tokens="$(jq '.usage.output_tokens // null' "$raw_result")"
    claude_cache_creation="$(jq '.usage.cache_creation_input_tokens // null' "$raw_result")"
    claude_cache_read="$(jq '.usage.cache_read_input_tokens // null' "$raw_result")"
    claude_result_text="$(jq -r '.result // empty' "$raw_result")"
  fi

  # Write manifest
  jq -n \
    --arg run_id "$run_id" \
    --arg repo "$repo" \
    --arg trigger_status "$status" \
    --arg status_after "$new_status" \
    --arg started_at "$started_at" \
    --arg finished_at "$finished_at" \
    --argjson wall_duration_s "$dur" \
    --argjson exit_code "$rc" \
    --arg branch_before "$branch_before" \
    --arg branch_after "$branch_after" \
    --arg head_before "$head_before" \
    --arg head_after "$head_after" \
    --argjson commits "$commits_json" \
    --arg session_id "$claude_session_id" \
    --arg subtype "$claude_subtype" \
    --argjson is_error "$claude_is_error" \
    --argjson num_turns "$claude_num_turns" \
    --argjson duration_ms "$claude_duration_ms" \
    --argjson duration_api_ms "$claude_duration_api_ms" \
    --argjson total_cost_usd "$claude_cost" \
    --argjson input_tokens "$claude_input_tokens" \
    --argjson output_tokens "$claude_output_tokens" \
    --argjson cache_creation "$claude_cache_creation" \
    --argjson cache_read "$claude_cache_read" \
    --arg log_rel ".handoff-logs/${run_id}-execute.log" \
    --arg raw_rel ".handoff-logs/${run_id}-result.json" \
    '{
      run_id: $run_id,
      repo: $repo,
      trigger_status: $trigger_status,
      status_after: $status_after,
      started_at: $started_at,
      finished_at: $finished_at,
      wall_duration_s: $wall_duration_s,
      exit_code: $exit_code,
      git: {
        branch_before: (if $branch_before == "" then null else $branch_before end),
        branch_after: (if $branch_after == "" then null else $branch_after end),
        head_before: (if $head_before == "" then null else $head_before end),
        head_after: (if $head_after == "" then null else $head_after end),
        commits: $commits
      },
      claude: {
        session_id: (if $session_id == "null" then null else $session_id end),
        subtype: (if $subtype == "null" then null else $subtype end),
        is_error: $is_error,
        num_turns: $num_turns,
        duration_ms: $duration_ms,
        duration_api_ms: $duration_api_ms,
        total_cost_usd: $total_cost_usd,
        usage: {
          input_tokens: $input_tokens,
          output_tokens: $output_tokens,
          cache_creation_input_tokens: $cache_creation,
          cache_read_input_tokens: $cache_read
        }
      },
      files: {
        log: $log_rel,
        raw_result: $raw_rel
      }
    }' > "$manifest"

  # Human-readable summary
  local summary
  summary="$(printf '
── Run Summary ─────────────────────────────────────────
  run:      %s
  status:   %s → %s
  duration: %dm %ds (wall)
  exit:     %d
  tokens:   %s in / %s out' \
    "$run_id" \
    "$status" "$new_status" \
    $((dur / 60)) $((dur % 60)) \
    "$rc" \
    "$(jq -r 'if .claude.usage.input_tokens then (.claude.usage.input_tokens | tostring) else "n/a" end' "$manifest")" \
    "$(jq -r 'if .claude.usage.output_tokens then (.claude.usage.output_tokens | tostring) else "n/a" end' "$manifest")")"

  # Cached tokens line (only if present)
  local cached_in
  cached_in="$(jq -r '[.claude.usage.cache_creation_input_tokens, .claude.usage.cache_read_input_tokens] | map(select(. != null)) | if length > 0 then map(tostring) | join(" + ") else empty end' "$manifest")"
  if [[ -n "$cached_in" ]]; then
    summary+="$(printf ' (cached: %s)' "$cached_in")"
  fi

  summary+="$(printf '\n  cost:    %s' \
    "$(jq -r 'if .claude.total_cost_usd then ("$" + (.claude.total_cost_usd | tostring)) else "n/a" end' "$manifest")")"

  # Commits
  local commit_count
  commit_count="$(jq '.git.commits | length' "$manifest")"
  if [[ "$commit_count" -gt 0 ]]; then
    summary+="$(printf '\n  commits:')"
    while IFS=$'\t' read -r sha subject url; do
      local shortsha="${sha:0:7}"
      if [[ "$url" != "null" && -n "$url" ]]; then
        summary+="$(printf '\n    %s %s\n         %s' "$shortsha" "$subject" "$url")"
      else
        summary+="$(printf '\n    %s %s' "$shortsha" "$subject")"
      fi
    done < <(jq -r '.git.commits[] | [.sha, .subject, (.url // "null")] | @tsv' "$manifest")
  fi

  summary+="$(printf '\n  manifest: %s\n────────────────────────────────────────────────────────\n' "$manifest")"

  # Print summary to stdout and append to log
  echo "$summary"

  {
    echo ""
    if [[ -n "$claude_result_text" ]]; then
      echo "=== Executor Result ==="
      echo "$claude_result_text"
      echo ""
    fi
    echo "$summary"
  } >> "$log"

  return "$rc"
}

cmd_runs() {
  command -v jq >/dev/null || die "jq is required (brew install jq)"

  local repo
  repo="$(resolve_repo "${1:-}")"

  local manifests=()
  while IFS= read -r f; do
    manifests+=("$f")
  done < <(find "$repo/.handoff-logs" -name '*-manifest.json' -type f 2>/dev/null | sort)

  if [[ ${#manifests[@]} -eq 0 ]]; then
    echo "no runs found in $repo/.handoff-logs/"
    return 0
  fi

  printf '%-22s  %-24s  %6s  %4s  %8s  %8s  %8s  %-16s  %s\n' \
    "RUN ID" "FINISHED" "WALL" "EXIT" "IN TOK" "OUT TOK" "COST" "STATUS AFTER" "COMMITS"
  printf '%-22s  %-24s  %6s  %4s  %8s  %8s  %8s  %-16s  %s\n' \
    "------" "--------" "----" "----" "------" "-------" "----" "------------" "-------"

  local m
  for m in "${manifests[@]}"; do
    jq -r '[
      .run_id,
      .finished_at,
      (.wall_duration_s | "\(. / 60 | floor)m \(. % 60)s"),
      (.exit_code | tostring),
      (if .claude.usage.input_tokens then (.claude.usage.input_tokens | tostring) else "n/a" end),
      (if .claude.usage.output_tokens then (.claude.usage.output_tokens | tostring) else "n/a" end),
      (if .claude.total_cost_usd then ("$" + (.claude.total_cost_usd | tostring)) else "n/a" end),
      .status_after,
      (.git.commits | length | tostring)
    ] | @tsv' "$m" | while IFS=$'\t' read -r rid fin wall ex itin outk cost sa cc; do
      printf '%-22s  %-24s  %6s  %4s  %8s  %8s  %8s  %-16s  %s\n' \
        "$rid" "$fin" "$wall" "$ex" "$itin" "$outk" "$cost" "$sa" "$cc"
    done
  done
}

cmd_watch() {
  local repo last="" status
  repo="$(resolve_repo "${1:-}")"
  echo "watching $repo/HANDOFF.md every ${POLL_INTERVAL}s (Ctrl-C to stop)"
  while true; do
    status="$(read_status "$repo")"
    if [[ "$status" != "$last" ]]; then
      echo "[$(date +%H:%M:%S)] status: $status ($(turn_for "$status")'s turn)"
      case "$status" in
        "READY FOR EXECUTION" | "CHANGES REQUESTED")
          if ! cmd_execute "$repo"; then
            # Don't hot-loop a failing executor: wait for the status (or a
            # human) to change something before trying again.
            echo "execute failed; watching for the next status change"
          fi
          ;;
        "READY FOR QA" | "APPROVED")
          notify "Handoff: $status" "$(read_goal "$repo")"
          ;;
      esac
      last="$status" # if execute changed the status, next poll handles the new state
    fi
    sleep "$POLL_INTERVAL"
  done
}

cmd_archive() {
  local repo archive goal
  repo="$(resolve_repo "${1:-}")"
  archive="$repo/HANDOFF-ARCHIVE.md"
  goal="$(read_goal "$repo")"
  if [[ ! -f "$archive" ]]; then
    printf '# HANDOFF Archive\n\nCompleted tasks, appended verbatim by `handoff archive`. Local-only (git-excluded).\n' > "$archive"
  fi
  {
    printf '\n---\n\n# Archived %s — %s\n\n' "$(date '+%Y-%m-%d %H:%M')" "${goal:-"(no goal)"}"
    # Current Task through QA Feedback are the last sections of the file.
    awk '/^## Current Task/ { found = 1 } found' "$repo/HANDOFF.md"
  } >> "$archive"
  echo "archived '$goal' to $archive"
}

# Merge the executor's permission rules into the repo's .claude/settings.json,
# preserving hooks, sandbox config, and anything else already there. The JS
# package manager is detected from the repo's lockfile so the allow rules
# match the project's actual toolchain (the executor runs headless, so any
# command outside these rules fails rather than prompting).
cmd_permissions() {
  command -v jq >/dev/null || die "jq is required (brew install jq)"
  local repo="${1:-$PWD}"
  repo="$(cd "$repo" 2>/dev/null && pwd)" || die "no such directory: ${1:-$PWD}"

  local pm=""
  if [[ -f "$repo/yarn.lock" ]]; then
    pm="yarn"
  elif [[ -f "$repo/pnpm-lock.yaml" ]]; then
    pm="pnpm"
  elif [[ -f "$repo/package-lock.json" ]]; then
    pm="npm"
  fi

  # Base rules: edits, navigation, local-only git. `cd` is included because
  # scripts often live in subpackages — a compound command like
  # `cd backend && yarn test` is only allowed if every part is.
  local -a allow=(
    "Edit" "Write" "Bash(cd:*)"
    "Bash(git add:*)" "Bash(git commit:*)"
    "Bash(git status)" "Bash(git status:*)"
    "Bash(git diff)" "Bash(git diff:*)"
    "Bash(git log)" "Bash(git log:*)"
  )

  # Verification scripts the executor may run itself. Deliberately a fixed
  # safe list — repo-specific extras (e.g. migration:generate) are a human
  # decision; add those to .claude/settings.json by hand.
  local -a scripts=(test lint check typecheck build pre-commit format)
  local s
  case "$pm" in
    yarn | pnpm)
      for s in "${scripts[@]}"; do allow+=("Bash($pm $s)" "Bash($pm $s:*)"); done
      ;;
    npm)
      allow+=("Bash(npm test)" "Bash(npm test:*)")
      for s in "${scripts[@]}"; do allow+=("Bash(npm run $s)" "Bash(npm run $s:*)"); done
      ;;
  esac
  if [[ -n "$pm" ]]; then
    allow+=("Bash(npx vitest:*)" "Bash(npx tsc:*)" "Bash(npx eslint:*)" "Bash(npx tsx:*)")
  fi

  # Publishing requires explicit human authorization written into the task —
  # and even then a human runs it. Deny beats allow in Claude Code.
  local -a deny=("Bash(git push:*)" "Bash(git merge:*)" "Bash(gh pr create:*)")

  local allow_json deny_json
  allow_json="$(printf '%s\n' "${allow[@]}" | jq -R . | jq -s .)"
  deny_json="$(printf '%s\n' "${deny[@]}" | jq -R . | jq -s .)"

  local settings="$repo/.claude/settings.json"
  mkdir -p "$repo/.claude"
  if [[ -f "$settings" ]]; then
    jq empty "$settings" 2>/dev/null || die "$settings is not valid JSON — fix it before merging"
    # Append-and-dedupe, preserving the order of anything already present.
    jq --argjson allow "$allow_json" --argjson deny "$deny_json" '
      .permissions.allow = ((.permissions.allow // []) + $allow
        | reduce .[] as $r ([]; if index($r) == null then . + [$r] else . end))
      | .permissions.deny = ((.permissions.deny // []) + $deny
        | reduce .[] as $r ([]; if index($r) == null then . + [$r] else . end))
    ' "$settings" > "$settings.tmp"
    mv "$settings.tmp" "$settings"
    echo "merged executor permissions into $settings (existing settings preserved)"
  else
    jq -n --argjson allow "$allow_json" --argjson deny "$deny_json" \
      '{permissions: {allow: $allow, deny: $deny}}' > "$settings"
    echo "created $settings with executor permissions"
  fi
  echo "toolchain: ${pm:-"none detected — git/edit rules only; add your build tool's commands by hand"}"
  echo "review:    git -C $repo diff .claude/settings.json"
}

cmd_init() {
  local repo="${1:-$PWD}"
  repo="$(cd "$repo" 2>/dev/null && pwd)" || die "no such directory: ${1:-$PWD}"
  [[ -d "$repo/.git" ]] || die "not a git repository: $repo"
  [[ -f "$repo/HANDOFF.md" ]] && die "HANDOFF.md already exists in $repo"
  [[ -f "$TEMPLATE_DIR/HANDOFF.md" ]] || die "template not found: $TEMPLATE_DIR/HANDOFF.md"

  cp "$TEMPLATE_DIR/HANDOFF.md" "$repo/HANDOFF.md"
  # Local-only excludes, deliberately NOT .gitignore: the handoff machinery
  # is this machine's workflow, not part of the project.
  local exclude="$repo/.git/info/exclude"
  mkdir -p "$repo/.git/info"
  local p
  for p in HANDOFF.md HANDOFF-ARCHIVE.md .handoff-logs/; do
    grep -qxF "$p" "$exclude" 2>/dev/null || echo "$p" >> "$exclude"
  done
  echo "initialized: $repo/HANDOFF.md (excluded locally via .git/info/exclude)"
  cmd_permissions "$repo"
}

case "${1:-}" in
  status | execute | runs | watch | archive | init | permissions) "cmd_$1" "${2:-}" ;;
  -h | --help | "") usage ;;
  *) die "unknown subcommand: $1 (try --help)" ;;
esac
